// ================================================================
// PAGE 3: TÂCHES
// ================================================================
function getTodayKey() {
  const d = new Date();
  return d.getFullYear() + '-' + (d.getMonth()+1) + '-' + d.getDate();
}

function initTasks(rewardPerTask) {
  const todayKey = getTodayKey();
  const savedKey = localStorage.getItem('wf_day');
  const savedTasks = localStorage.getItem('wf_tasks');

  if (savedKey === todayKey && savedTasks) {
    // Same day: restore saved progress
    tasks = JSON.parse(savedTasks);
    // Update reward in case deposit changed
    tasks = tasks.map(t => ({ ...t, reward: rewardPerTask }));
  } else {
    // New day: fresh tasks
    tasks = TASKS_DEF.map(t => ({
      ...t,
      reward: rewardPerTask,
      status: 'pending',
    }));
    localStorage.setItem('wf_day', todayKey);
    saveTasks();
  }
  renderTasks();
}

function saveTasks() {
  localStorage.setItem('wf_tasks', JSON.stringify(tasks));
}

function renderTasks() {
  const container = document.getElementById('tasks-container');
  container.innerHTML = '';

  const done = tasks.filter(t => t.status === 'done').length;
  document.getElementById('tasks-count').textContent = done + ' / ' + tasks.length;
  const pct = tasks.length ? (done/tasks.length)*100 : 0;
  document.getElementById('progress-bar').style.width = pct + '%';

  tasks.forEach(task => {
    const div = document.createElement('div');
    div.className = 'task-card fade-up' + (task.status==='done' ? ' done' : task.status==='in-progress' ? ' in-progress' : '');
    div.id = 'task-'+task.id;

    let actions = '';
    if (task.status === 'pending') {
      actions = `<button class="btn-gold-sm" onclick="startTask(${task.id})">▶ Commencer</button>`;
    } else if (task.status === 'in-progress') {
      actions = `
        <span style="font-size:0.8rem;color:var(--gold);">⏳ En cours...</span>
        <button class="btn-green" onclick="doneTask(${task.id})">✓ Terminé</button>
      `;
    } else {
      actions = `<div class="task-status">✅ Complété</div>`;
    }

    const platformColor = task.platform === 'TikTok' ? '#ff0050' : task.platform === 'Instagram' ? '#e1306c' : '#1877f2';
    div.innerHTML = `
      <div class="task-icon">${task.icon}</div>
      <div class="task-info">
        <div class="task-name">${task.name}</div>
        <div style="display:flex; align-items:center; gap:6px; margin-top:4px; flex-wrap:wrap;">
          <span style="background:${platformColor}22; color:${platformColor}; font-size:0.75rem; font-weight:700; padding:2px 10px; border-radius:20px;">${task.platform}</span>
          <span style="color:var(--muted); font-size:0.78rem;">${task.type}</span>
        </div>
        ${task.status === 'in-progress' && task.url ? `<a href="${task.url}" target="_blank" style="display:inline-flex; align-items:center; gap:4px; margin-top:8px; background:${platformColor}; color:white; font-size:0.78rem; font-weight:600; padding:5px 12px; border-radius:6px; text-decoration:none;">🔗 Ouvrir ${task.platform}</a><div style="font-size:0.75rem; color:var(--muted); margin-top:4px;">${task.instruction}</div>` : ''}
      </div>
      <div class="task-reward">+${task.reward ? task.reward.toLocaleString('fr-FR') : '—'} FCFA</div>
      <div class="task-actions">${actions}</div>
    `;
    container.appendChild(div);
  });
}

function startTask(id) {
  const task = tasks.find(t => t.id === id);
  if (!task || task.status !== 'pending') return;
  task.status = 'in-progress';
  saveTasks();
  renderTasks();
  showToast('▶ Mission démarrée — effectuez la tâche puis cliquez Terminé');
}

function doneTask(id) {
  const task = tasks.find(t => t.id === id);
  if (!task || task.status !== 'in-progress') return;
  task.status = 'done';
  saveTasks();

  appState.balance += task.reward;
  updateNavBalance();

  const entry = {
    taskName: task.name,
    platform: task.platform,
    reward: task.reward,
    time: new Date().toLocaleString('fr-FR'),
    user: appState.currentUser?.nom + ' ' + appState.currentUser?.prenom,
  };
  appState.history.push(entry);
  allCompletedTasks.push(entry);

  renderTasks();
  showToast('🎉 +' + task.reward.toLocaleString('fr-FR') + ' FCFA ajoutés à votre solde !', 'success');

  const el = document.getElementById('task-'+id);
  if(el) { el.classList.add('pulse'); setTimeout(()=>el.classList.remove('pulse'),400); }
}

function updateNavBalance() {
  const b = appState.balance.toLocaleString('fr-FR');
  const el1 = document.getElementById('nav-balance-display');
  const el2 = document.getElementById('nav-balance-display2');
  if(el1) el1.textContent = b;
  if(el2) el2.textContent = b;
}

function resetTasks() {
  if(!appState.depositAmount){ showToast("Veuillez d'abord effectuer un dépôt", 'error'); return; }
  localStorage.removeItem('wf_day');
  localStorage.removeItem('wf_tasks');
  const info = GAINS_MAP[appState.depositAmount];
  initTasks(info.reward);
  showToast("🔄 Nouvelles missions disponibles pour aujourd'hui !");
