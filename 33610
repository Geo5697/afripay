  if (!nom || !prenom || !email || !tel) { showToast('⚠️ Tous les champs sont obligatoires', 'error'); return; }
  if (!email.includes('@gmail.com')) { showToast('⚠️ Veuillez utiliser une adresse Gmail', 'error'); return; }
  if (tel.replace(/\D/g,'').length < 8) { showToast('⚠️ Numéro de téléphone invalide', 'error'); return; }

