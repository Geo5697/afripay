      </tr>`).join('')}</tbody>
    </table>
  ` : '<div class="empty"><div class="empty-icon">💸</div><p>Aucun retrait pour l\'instant.</p></div>';

  // KYC table
  document.getElementById('tab-kyc').innerHTML = allKyc.length ? `
    <table class="admin-table">
      <thead><tr><th>Utilisateur</th><th>Email</th><th>Fichier</th><th>Date</th><th>Statut</th><th>Action</th></tr></thead>
      <tbody>${allKyc.map((k,i)=>`<tr>
        <td>${k.user}</td>
        <td style="color:var(--muted)">${k.email}</td>
        <td style="color:var(--blue)">${k.fichier}</td>
        <td style="color:var(--muted)">${k.date}</td>
        <td><span class="badge badge-gold">⏳ ${k.statut}</span></td>
        <td style="display:flex;gap:6px;">
          <button onclick="approuverKyc(${i})" style="background:var(--green);color:white;border:none;padding:5px 10px;border-radius:6px;cursor:pointer;font-size:0.75rem;">✓ Approuver</button>
          <button onclick="rejeterKyc(${i})" style="background:var(--red);color:white;border:none;padding:5px 10px;border-radius:6px;cursor:pointer;font-size:0.75rem;">✗ Rejeter</button>
        </td>
      </tr>`).join('')}</tbody>
    </table>
  ` : '<div class="empty"><div class="empty-icon">🪪</div><p>Aucune vérification en attente.</p></div>';
}

function approuverKyc(i) {
  allKyc[i].statut = 'Approuvé';
  refreshAdmin();
  showToast('✅ Vérification approuvée', 'success');
}

function rejeterKyc(i) {
  allKyc[i].statut = 'Rejeté';
  refreshAdmin();
  showToast('❌ Vérification rejetée', 'error');
}

function adminTab(el, tabId) {
  document.querySelectorAll('.admin-tab').forEach(t => t.classList.remove('active'));
  el.classList.add('active');
  document.querySelectorAll('.admin-section').forEach(s => s.style.display='none');
  document.getElementById(tabId).style.display='block';
}

// ================================================================
// PROFIL PAGE
// ================================================================
function updateProfilPage() {
  const u = appState.currentUser;
  if (!u) return;
  const initials = (u.prenom ? u.prenom[0] : '') + (u.nom ? u.nom[0] : '');
  document.getElementById('profil-avatar').textContent = initials.toUpperCase();
  document.getElementById('profil-nom-display').textContent = u.prenom + ' ' + u.nom;
  document.getElementById('profil-email-display').textContent = '✉️ ' + u.email;
  document.getElementById('profil-tel-display').textContent = '📱 ' + u.tel;
  document.getElementById('edit-nom').value = u.nom;
  document.getElementById('edit-prenom').value = u.prenom;
  document.getElementById('edit-tel').value = u.tel;
  document.getElementById('profil-stat-taches').textContent = appState.history.length;
  document.getElementById('profil-stat-gains').textContent = appState.balance.toLocaleString('fr-FR');
  document.getElementById('profil-stat-depot').textContent = appState.depositAmount ? appState.depositAmount.toLocaleString('fr-FR') : '—';

  const el4 = document.getElementById('nav-balance-display4');
  if (el4) el4.textContent = appState.balance.toLocaleString('fr-FR');

  if (appState.kycSubmitted) {
    document.getElementById('profil-verified-badge').style.display = 'block';
    document.getElementById('profil-unverified-badge').style.display = 'none';
    document.getElementById('kyc-submitted').style.display = 'block';
    document.getElementById('kyc-upload-zone').style.display = 'none';
    document.getElementById('kyc-preview').style.display = 'none';
  }
}

function handleKycUpload(event) {
  const file = event.target.files[0];
  if (!file) return;
  if (file.size > 5 * 1024 * 1024) { showToast('⚠️ Fichier trop lourd (max 5 Mo)', 'error'); return; }
  document.getElementById('kyc-filename').textContent = file.name;
  document.getElementById('kyc-preview').style.display = 'block';
  document.getElementById('kyc-upload-zone').style.display = 'none';
  appState.kycFile = file.name;
}

function soumettreKyc() {
  if (!appState.kycFile) { showToast('⚠️ Veuillez uploader votre pièce d'identité', 'error'); return; }
  appState.kycSubmitted = true;
  document.getElementById('kyc-preview').style.display = 'none';
  document.getElementById('kyc-submitted').style.display = 'block';
  document.getElementById('profil-verified-badge').style.display = 'block';
  document.getElementById('profil-unverified-badge').style.display = 'none';
  // Add to admin
  allKyc.push({
    user: appState.currentUser?.nom + ' ' + appState.currentUser?.prenom,
    email: appState.currentUser?.email,
    fichier: appState.kycFile,
    date: new Date().toLocaleString('fr-FR'),
    statut: 'En attente'
  });
  showToast('✅ Document soumis ! Vérification sous 24h.', 'success');
}

function sauvegarderProfil() {
  const nom = document.getElementById('edit-nom').value.trim();
  const prenom = document.getElementById('edit-prenom').value.trim();
  const tel = document.getElementById('edit-tel').value.trim();
  if (!nom || !prenom || !tel) { showToast('⚠️ Tous les champs sont requis', 'error'); return; }
  appState.currentUser.nom = nom;
  appState.currentUser.prenom = prenom;
  appState.currentUser.tel = tel;
  updateProfilPage();
  showToast('✅ Profil mis à jour avec succès !', 'success');
}
