    return;
  }
  list.innerHTML = [...appState.history].reverse().map(h => `
    <div class="history-item">
      <div class="history-left">
        <div class="history-icon">${h.platform==='TikTok'?'🎵':'💬'}</div>
        <div>
          <div class="history-name">${h.taskName}</div>
          <div class="history-time">📲 ${h.platform} · ${h.time}</div>
        </div>
      </div>
      <div class="history-amount">+${h.reward.toLocaleString('fr-FR')} FCFA</div>
    </div>
  `).join('');
}

