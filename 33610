function soumettreRetrait() {
  const montant = parseInt(document.getElementById('retrait-montant').value) || 0;
  const indicatif = document.getElementById('retrait-indicatif').value;
  const numero = document.getElementById('retrait-numero').value.trim();
  const nom = document.getElementById('retrait-nom').value.trim();

  if (!appState.kycSubmitted) { showToast('⚠️ Vérifiez votre identité dans Mon Profil avant de retirer.', 'error'); goTo('page-profil'); return; }
  if (!montant || montant < 8500) { showToast('⚠️ Montant minimum : 8 500 FCFA', 'error'); return; }
  if (montant > appState.balance) { showToast('⚠️ Solde insuffisant', 'error'); return; }
  if (!selectedOperateur) { showToast('⚠️ Choisissez un opérateur Mobile Money', 'error'); return; }
  if (!numero) { showToast('⚠️ Entrez votre numéro Mobile Money', 'error'); return; }
  if (!nom) { showToast('⚠️ Entrez le nom du titulaire', 'error'); return; }

  // Deduct balance
  appState.balance -= montant;
  updateNavBalance();

  const entry = {
    montant,
    operateur: selectedOperateur,
    numero: indicatif + ' ' + numero,
    nom,
    date: new Date().toLocaleString('fr-FR'),
    statut: 'En cours'
  };
  retraitHistory.unshift(entry);
  allRetraits.push({ ...entry, user: appState.currentUser?.nom + ' ' + appState.currentUser?.prenom });

  // Reset form
  document.getElementById('retrait-montant').value = '';
  document.getElementById('retrait-numero').value = '';
  document.getElementById('retrait-nom').value = '';
  document.getElementById('retrait-montant-msg').textContent = '';
  document.querySelectorAll('#page-retrait .payment-option').forEach(o => o.classList.remove('selected'));
  selectedOperateur = null;

  renderRetraitHistory();
  updateRetraitSolde();
  showToast('✅ Demande de retrait envoyée ! Traitement sous 24-48h.', 'success');
}

function renderRetraitHistory() {
  const el = document.getElementById('retrait-history');
  if (!retraitHistory.length) {
    el.innerHTML = '<div class="empty"><div class="empty-icon">💸</div><p>Aucun retrait effectué.</p></div>';
    return;
  }
  el.innerHTML = retraitHistory.map(r => `
    <div class="history-item" style="margin-bottom:10px; flex-wrap:wrap; gap:8px;">
      <div class="history-left">
        <div class="history-icon">💸</div>
        <div>
          <div class="history-name">${r.operateur} · ${r.numero}</div>
          <div class="history-time">👤 ${r.nom} · ${r.date}</div>
        </div>
      </div>
      <div style="display:flex; align-items:center; gap:10px;">
        <span style="font-family:var(--font-head); font-weight:700; color:var(--red); font-size:0.95rem;">-${r.montant.toLocaleString('fr-FR')} FCFA</span>
        <span class="badge badge-gold">⏳ ${r.statut}</span>
      </div>
    </div>
  `).join('');
}

function updateRetraitSolde() {
  const el = document.getElementById('retrait-solde-dispo');
  const el3 = document.getElementById('nav-balance-display3');
  if (el) el.textContent = appState.balance.toLocaleString('fr-FR') + ' FCFA';
  if (el3) el3.textContent = appState.balance.toLocaleString('fr-FR');
}

