// ================================================================
// PAGE: PROFIL
// ================================================================
let kycSubmitted = false;

function updateProfilPage() {
  const u = appState.currentUser;
  if (!u) return;
  const initials = (u.prenom ? u.prenom[0] : '') + (u.nom ? u.nom[0] : '');
  document.getElementById('profil-avatar').textContent = initials.toUpperCase() || '?';
  document.getElementById('profil-nom-display').textContent = u.prenom + ' ' + u.nom;
  document.getElementById('profil-email-display').textContent = u.email;
  document.getElementById('profil-nom').textContent = u.nom;
  document.getElementById('profil-prenom').textContent = u.prenom;
  document.getElementById('profil-email').textContent = u.email;
  document.getElementById('profil-tel').textContent = u.tel;
  document.getElementById('profil-stat-solde').textContent = appState.balance.toLocaleString('fr-FR');
  document.getElementById('profil-stat-taches').textContent = appState.history.length;
  document.getElementById('profil-stat-depot').textContent = appState.depositAmount ? appState.depositAmount.toLocaleString('fr-FR') + ' F' : '—';
  const nb4 = document.getElementById('nav-balance-display4');
  if (nb4) nb4.textContent = appState.balance.toLocaleString('fr-FR');

  if (kycSubmitted) {
    document.getElementById('kyc-form').style.display = 'none';
    document.getElementById('kyc-status-box').style.display = 'block';
  }
}

function previewKYC(input, previewId, dropId) {
  const file = input.files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = function(e) {
    const img = document.getElementById(previewId);
    img.src = e.target.result;
    img.style.display = 'block';
    document.getElementById(dropId).style.display = 'none';
  };
  reader.readAsDataURL(file);
}

function soumettreKYC() {
  const type = document.getElementById('kyc-type').value;
  const recto = document.getElementById('kyc-file-recto').files[0];
  if (!type) { showToast('⚠️ Choisissez le type de document', 'error'); return; }
  if (!recto) { showToast('⚠️ Ajoutez la photo recto de votre pièce', 'error'); return; }
  kycSubmitted = true;
  // Save to admin
  allKYC.push({
    user: (appState.currentUser?.prenom || '') + ' ' + (appState.currentUser?.nom || ''),
    email: appState.currentUser?.email || '',
    type: type,
    date: new Date().toLocaleString('fr-FR'),
    statut: 'En attente'
  });
  document.getElementById('kyc-form').style.display = 'none';
  document.getElementById('kyc-status-box').style.display = 'block';
  showToast('✅ Pièce soumise ! Vérification sous 24h.', 'success');
}

function deconnexion() {
  appState = { currentUser: null, balance: 0, depositAmount: 0, history: [], selectedPayment: null };
  tasks = [];
  kycSubmitted = false;
  selectedOperateur = null;
  retraitHistory = [];
  goTo('page-inscription');
  showToast('👋 Vous avez été déconnecté.');
}

function adminLogin() {
  const u = document.getElementById('admin-user').value;
  const p = document.getElementById('admin-pass').value;
  if (u === 'admin' && p === 'admin123') {
    refreshAdmin();
    goTo('page-admin');
  } else {
    showToast('❌ Identifiants incorrects', 'error');
  }
}

function adminLogout() {
  goTo('page-admin-login');
}

function refreshAdmin() {
  // Stats
  document.getElementById('admin-stats').innerHTML = `
    <div class="admin-stat"><div class="admin-stat-num">${allUsers.length}</div><div class="admin-stat-lbl">Utilisateurs inscrits</div></div>
    <div class="admin-stat"><div class="admin-stat-num" style="color:var(--gold)">${allPayments.reduce((s,p)=>s+p.montant,0).toLocaleString('fr-FR')} FCFA</div><div class="admin-stat-lbl">Total paiements</div></div>
    <div class="admin-stat"><div class="admin-stat-num" style="color:var(--green)">${allCompletedTasks.length}</div><div class="admin-stat-lbl">Tâches terminées</div></div>
    <div class="admin-stat"><div class="admin-stat-num" style="color:var(--blue)">${allPayments.length}</div><div class="admin-stat-lbl">Transactions</div></div>
    <div class="admin-stat"><div class="admin-stat-num" style="color:#a855f7">${allKYC.length}</div><div class="admin-stat-lbl">KYC soumis</div></div>
  `;

  // Users table
  document.getElementById('tab-users').innerHTML = allUsers.length ? `
    <table class="admin-table">
      <thead><tr><th>#</th><th>Nom</th><th>Email</th><th>Téléphone</th><th>Date</th><th>Statut</th></tr></thead>
      <tbody>${allUsers.map(u=>`<tr>
        <td>${u.id}</td>
        <td>${u.nom} ${u.prenom}</td>
        <td>${u.email}</td>
        <td>${u.tel}</td>
        <td>${u.dateInscription}</td>
        <td><span class="badge badge-green">✓ Actif</span></td>
      </tr>`).join('')}</tbody>
    </table>
  ` : '<div class="empty"><div class="empty-icon">👥</div><p>Aucune inscription pour l\'instant.</p></div>';

  // Payments table
  document.getElementById('tab-payments').innerHTML = allPayments.length ? `
    <table class="admin-table">
      <thead><tr><th>#</th><th>Utilisateur</th><th>Montant</th><th>Référence</th><th>Date</th><th>Statut</th></tr></thead>
      <tbody>${allPayments.map(p=>`<tr>
        <td>${p.id}</td>
        <td>${p.user}</td>
        <td><strong style="color:var(--gold)">${p.montant.toLocaleString('fr-FR')} FCFA</strong></td>
        <td style="color:var(--muted);font-size:0.78rem;">${p.reference || '—'}</td>
        <td>${p.date}</td>
        <td><span class="badge badge-green">✓ ${p.status}</span></td>
      </tr>`).join('')}</tbody>
    </table>
  ` : '<div class="empty"><div class="empty-icon">💳</div><p>Aucun paiement pour l\'instant.</p></div>';

  // Tasks table
  document.getElementById('tab-tasks').innerHTML = allCompletedTasks.length ? `
    <table class="admin-table">
      <thead><tr><th>Tâche</th><th>Plateforme</th><th>Utilisateur</th><th>Gain</th><th>Heure</th></tr></thead>
      <tbody>${allCompletedTasks.map(t=>`<tr>
        <td>${t.taskName}</td>
        <td><span class="badge ${t.platform==='TikTok'?'badge-blue':'badge-gold'}">${t.platform}</span></td>
        <td>${t.user}</td>
        <td style="color:var(--green);font-weight:600;">+${t.reward.toLocaleString('fr-FR')} FCFA</td>
        <td style="color:var(--muted)">${t.time}</td>
      </tr>`).join('')}</tbody>
    </table>
  ` : '<div class="empty"><div class="empty-icon">✅</div><p>Aucune tâche terminée pour l\'instant.</p></div>';

  // KYC table
  document.getElementById('tab-kyc').innerHTML = allKYC.length ? `
    <table class="admin-table">
      <thead><tr><th>Utilisateur</th><th>Email</th><th>Type document</th><th>Date soumission</th><th>Statut</th></tr></thead>
      <tbody>${allKYC.map(k=>`<tr>
        <td>${k.user}</td>
        <td>${k.email}</td>
        <td>${k.type}</td>
        <td style="color:var(--muted)">${k.date}</td>
        <td><span class="badge badge-gold">⏳ ${k.statut}</span></td>
      </tr>`).join('')}</tbody>
    </table>
  ` : '<div class="empty"><div class="empty-icon">🪪</div><p>Aucune vérification soumise.</p></div>';

  // Retraits table
  document.getElementById('tab-retraits').innerHTML = allRetraits.length ? `
    <table class="admin-table">
      <thead><tr><th>Utilisateur</th><th>Montant</th><th>Opérateur</th><th>Numéro</th><th>Date</th><th>Statut</th></tr></thead>
      <tbody>${allRetraits.map(r=>`<tr>
        <td>${r.user}</td>
        <td style="color:var(--red);font-weight:600;">-${r.montant.toLocaleString('fr-FR')} FCFA</td>
        <td>${r.operateur}</td>
        <td>${r.numero}</td>
        <td style="color:var(--muted)">${r.date}</td>
