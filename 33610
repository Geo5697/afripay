<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>WorkFlow Africa — Plateforme de Travail en Ligne</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">

<style>
  :root {
    --gold: #F5C518;
    --gold-light: #FFD84D;
    --dark: #0A0A0F;
    --dark2: #12121A;
    --dark3: #1C1C28;
    --card: #1E1E2E;
    --border: rgba(245,197,24,0.18);
    --text: #E8E8F0;
    --muted: #7A7A9A;
    --green: #22C55E;
    --red: #EF4444;
    --blue: #3B82F6;
    --radius: 16px;
    --font-head: 'Syne', sans-serif;
    --font-body: 'DM Sans', sans-serif;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: var(--font-body);
    background: var(--dark);
    color: var(--text);
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* ========= PAGES ========= */
  .page { display: none; min-height: 100vh; }
  .page.active { display: flex; flex-direction: column; }

  /* ========= BACKGROUND EFFECTS ========= */
  .bg-glow {
    position: fixed; inset: 0; pointer-events: none; z-index: 0;
    background:
      radial-gradient(ellipse 60% 40% at 20% 20%, rgba(245,197,24,0.07) 0%, transparent 70%),
      radial-gradient(ellipse 50% 30% at 80% 80%, rgba(59,130,246,0.05) 0%, transparent 70%);
  }

  /* ========= NAV ========= */
  .nav {
    display: flex; align-items: center; justify-content: space-between;
    padding: 18px 28px; border-bottom: 1px solid var(--border);
    background: rgba(10,10,15,0.9); backdrop-filter: blur(12px);
    position: sticky; top: 0; z-index: 100;
  }
  .nav-logo { font-family: var(--font-head); font-size: 1.3rem; font-weight: 800; color: var(--gold); letter-spacing: -0.5px; }
  .nav-logo span { color: var(--text); }
  .nav-links { display: flex; gap: 8px; }
  .nav-btn {
    background: transparent; border: 1px solid var(--border); color: var(--muted);
    padding: 8px 16px; border-radius: 8px; cursor: pointer; font-family: var(--font-body);
    font-size: 0.85rem; transition: all 0.2s;
  }
  .nav-btn:hover, .nav-btn.active-nav { background: var(--gold); color: var(--dark); border-color: var(--gold); font-weight: 600; }
  .nav-balance { font-family: var(--font-head); font-weight: 700; color: var(--gold); font-size: 0.95rem; display: flex; align-items: center; gap: 6px; }

  /* ========= CONTENT ========= */
  .content { flex: 1; padding: 40px 20px; max-width: 520px; margin: 0 auto; width: 100%; position: relative; z-index: 1; }
  .content-wide { max-width: 900px; }

  /* ========= HEADINGS ========= */
  .page-title { font-family: var(--font-head); font-size: 2rem; font-weight: 800; margin-bottom: 6px; line-height: 1.1; }
  .page-title span { color: var(--gold); }
  .page-sub { color: var(--muted); font-size: 0.95rem; margin-bottom: 32px; }

  /* ========= CARD ========= */
  .card {
    background: var(--card); border: 1px solid var(--border);
    border-radius: var(--radius); padding: 28px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.4);
  }

  /* ========= FORM ========= */
  .form-group { margin-bottom: 20px; }
  .form-label { display: block; font-size: 0.85rem; color: var(--muted); margin-bottom: 8px; font-weight: 500; letter-spacing: 0.3px; }
  .form-input {
    width: 100%; background: var(--dark3); border: 1px solid var(--border);
    color: var(--text); padding: 14px 16px; border-radius: 10px;
    font-family: var(--font-body); font-size: 0.95rem; transition: all 0.2s; outline: none;
  }
  .form-input:focus { border-color: var(--gold); box-shadow: 0 0 0 3px rgba(245,197,24,0.1); }
  .form-input::placeholder { color: var(--muted); }

  /* ========= BUTTONS ========= */
  .btn-primary {
    width: 100%; background: var(--gold); color: var(--dark); border: none;
    padding: 15px 24px; border-radius: 10px; font-family: var(--font-head);
    font-size: 1rem; font-weight: 700; cursor: pointer; transition: all 0.2s;
    letter-spacing: 0.3px;
  }
  .btn-primary:hover { background: var(--gold-light); transform: translateY(-1px); box-shadow: 0 6px 20px rgba(245,197,24,0.3); }
  .btn-primary:active { transform: translateY(0); }

  .btn-outline {
    background: transparent; border: 1px solid var(--border); color: var(--text);
    padding: 10px 18px; border-radius: 8px; cursor: pointer; font-family: var(--font-body);
    font-size: 0.9rem; transition: all 0.2s;
  }
  .btn-outline:hover { border-color: var(--gold); color: var(--gold); }

  .btn-green { background: var(--green); color: white; border: none; padding: 9px 16px; border-radius: 8px; cursor: pointer; font-size: 0.85rem; font-weight: 600; transition: all 0.2s; }
  .btn-green:hover { background: #16a34a; }
  .btn-green:disabled { background: #166534; color: #4ade80; cursor: not-allowed; opacity: 0.6; }

  .btn-gold-sm { background: var(--gold); color: var(--dark); border: none; padding: 9px 16px; border-radius: 8px; cursor: pointer; font-size: 0.85rem; font-weight: 700; transition: all 0.2s; }
  .btn-gold-sm:hover { background: var(--gold-light); }
  .btn-gold-sm:disabled { background: #7a6200; color: #cca800; cursor: not-allowed; }

  /* ========= PAYMENT OPTIONS ========= */
  .payment-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(120px, 1fr)); gap: 12px; margin-bottom: 24px; }
  .payment-option {
    background: var(--dark3); border: 2px solid var(--border); border-radius: 12px;
    padding: 16px 12px; text-align: center; cursor: pointer; transition: all 0.2s;
  }
  .payment-option:hover { border-color: var(--gold); }
  .payment-option.selected { border-color: var(--gold); background: rgba(245,197,24,0.08); }
  .payment-option .amount { font-family: var(--font-head); font-size: 1.1rem; font-weight: 700; color: var(--gold); }
  .payment-option .currency { font-size: 0.75rem; color: var(--muted); margin-top: 2px; }
  .payment-option .check { font-size: 1.2rem; margin-bottom: 8px; }

  /* ========= TASKS ========= */
  .task-card {
    background: var(--card); border: 1px solid var(--border); border-radius: var(--radius);
    padding: 20px; margin-bottom: 14px; transition: all 0.2s;
    display: flex; align-items: center; gap: 16px; flex-wrap: wrap;
  }
  .task-card.done { border-color: var(--green); background: rgba(34,197,94,0.05); }
  .task-card.in-progress { border-color: var(--gold); background: rgba(245,197,24,0.05); }

  .task-icon { font-size: 1.8rem; flex-shrink: 0; }
  .task-info { flex: 1; min-width: 160px; }
  .task-name { font-family: var(--font-head); font-weight: 600; font-size: 0.95rem; margin-bottom: 4px; }
  .task-platform { font-size: 0.8rem; color: var(--muted); }
  .task-reward { font-family: var(--font-head); font-weight: 700; color: var(--gold); font-size: 1rem; white-space: nowrap; }
  .task-actions { display: flex; gap: 8px; align-items: center; flex-wrap: wrap; }
  .task-status { font-size: 0.8rem; color: var(--green); font-weight: 600; display: flex; align-items: center; gap: 4px; }

  /* ========= BALANCE PAGE ========= */
  .balance-big { font-family: var(--font-head); font-size: 3rem; font-weight: 800; color: var(--gold); text-align: center; margin: 20px 0 6px; }
  .balance-label { text-align: center; color: var(--muted); font-size: 0.9rem; margin-bottom: 32px; }

  .stats-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; margin-bottom: 28px; }
  .stat-box { background: var(--card); border: 1px solid var(--border); border-radius: 12px; padding: 18px; text-align: center; }
  .stat-num { font-family: var(--font-head); font-size: 1.5rem; font-weight: 700; color: var(--text); }
  .stat-lbl { font-size: 0.75rem; color: var(--muted); margin-top: 4px; }

  .history-item {
    background: var(--card); border: 1px solid var(--border); border-radius: 10px;
    padding: 14px 18px; margin-bottom: 10px; display: flex; align-items: center; justify-content: space-between;
  }
  .history-left { display: flex; align-items: center; gap: 12px; }
  .history-icon { font-size: 1.2rem; }
  .history-name { font-size: 0.9rem; font-weight: 500; }
  .history-time { font-size: 0.75rem; color: var(--muted); margin-top: 2px; }
  .history-amount { font-family: var(--font-head); font-weight: 700; color: var(--green); font-size: 0.95rem; }

  /* ========= ADMIN ========= */
  .admin-login { max-width: 380px; margin: 60px auto; }
  .admin-tabs { display: flex; gap: 8px; margin-bottom: 24px; flex-wrap: wrap; }
  .admin-tab { background: var(--dark3); border: 1px solid var(--border); color: var(--muted); padding: 10px 20px; border-radius: 8px; cursor: pointer; font-size: 0.9rem; transition: all 0.2s; }
  .admin-tab.active { background: var(--gold); color: var(--dark); font-weight: 700; border-color: var(--gold); }

  .admin-table { width: 100%; border-collapse: collapse; font-size: 0.85rem; }
  .admin-table th { text-align: left; color: var(--muted); font-weight: 500; padding: 12px 14px; border-bottom: 1px solid var(--border); }
  .admin-table td { padding: 13px 14px; border-bottom: 1px solid rgba(255,255,255,0.05); }
  .admin-table tr:hover td { background: rgba(255,255,255,0.02); }

  .badge { display: inline-flex; align-items: center; gap: 4px; padding: 3px 10px; border-radius: 20px; font-size: 0.75rem; font-weight: 600; }
  .badge-green { background: rgba(34,197,94,0.15); color: var(--green); }
  .badge-gold { background: rgba(245,197,24,0.15); color: var(--gold); }
  .badge-blue { background: rgba(59,130,246,0.15); color: var(--blue); }

  .admin-stat-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 14px; margin-bottom: 28px; }
  .admin-stat { background: var(--card); border: 1px solid var(--border); border-radius: 12px; padding: 20px; }
  .admin-stat-num { font-family: var(--font-head); font-size: 1.8rem; font-weight: 800; color: var(--gold); }
  .admin-stat-lbl { color: var(--muted); font-size: 0.8rem; margin-top: 4px; }

  /* ========= HERO ========= */
  .hero { text-align: center; padding: 60px 20px 20px; position: relative; z-index: 1; }
  .hero-badge { display: inline-flex; align-items: center; gap: 6px; background: rgba(245,197,24,0.1); border: 1px solid rgba(245,197,24,0.3); color: var(--gold); padding: 6px 16px; border-radius: 20px; font-size: 0.8rem; font-weight: 600; margin-bottom: 24px; }
  .hero-title { font-family: var(--font-head); font-size: clamp(2.2rem, 6vw, 3.5rem); font-weight: 800; line-height: 1.05; margin-bottom: 16px; }
  .hero-title span { color: var(--gold); }
  .hero-desc { color: var(--muted); font-size: 1rem; max-width: 420px; margin: 0 auto 36px; line-height: 1.7; }

  /* ========= TOAST ========= */
  .toast {
    position: fixed; bottom: 24px; left: 50%; transform: translateX(-50%) translateY(80px);
    background: var(--card); border: 1px solid var(--border); color: var(--text);
    padding: 14px 24px; border-radius: 10px; font-size: 0.9rem; z-index: 9999;
    transition: transform 0.3s; box-shadow: 0 8px 32px rgba(0,0,0,0.5);
    white-space: nowrap;
  }
  .toast.show { transform: translateX(-50%) translateY(0); }
  .toast.success { border-color: var(--green); }
  .toast.error { border-color: var(--red); }

  /* ========= STEP INDICATOR ========= */
  .steps { display: flex; align-items: center; justify-content: center; gap: 0; margin-bottom: 36px; }
  .step { display: flex; align-items: center; }
  .step-num { width: 32px; height: 32px; border-radius: 50%; border: 2px solid var(--border); display: flex; align-items: center; justify-content: center; font-size: 0.8rem; font-weight: 700; color: var(--muted); transition: all 0.3s; }
  .step-num.done { background: var(--green); border-color: var(--green); color: white; }
  .step-num.active { background: var(--gold); border-color: var(--gold); color: var(--dark); }
  .step-line { width: 48px; height: 2px; background: var(--border); }
  .step-line.done { background: var(--green); }

  /* ========= DIVIDER ========= */
  .divider { border: none; border-top: 1px solid var(--border); margin: 24px 0; }

  /* ========= SECTION TITLE ========= */
  .section-title { font-family: var(--font-head); font-size: 1.1rem; font-weight: 700; margin-bottom: 16px; display: flex; align-items: center; gap: 8px; }
  .section-title::after { content: ''; flex: 1; height: 1px; background: var(--border); }

  /* ========= EMPTY STATE ========= */
  .empty { text-align: center; padding: 40px 20px; color: var(--muted); }
  .empty-icon { font-size: 3rem; margin-bottom: 12px; }

  /* ========= RESPONSIVE ========= */
  @media (max-width: 480px) {
    .nav { padding: 14px 16px; }
    .nav-logo { font-size: 1.1rem; }
    .content { padding: 24px 14px; }
    .stats-grid { grid-template-columns: repeat(3, 1fr); gap: 8px; }
    .stat-box { padding: 12px 8px; }
    .stat-num { font-size: 1.2rem; }
    .task-card { gap: 12px; }
    .admin-table { font-size: 0.78rem; }
    .admin-table th, .admin-table td { padding: 10px 8px; }
  }

  /* ========= SCROLLBAR ========= */
  ::-webkit-scrollbar { width: 6px; }
  ::-webkit-scrollbar-track { background: var(--dark); }
  ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }

  /* ========= ANIMATIONS ========= */
  @keyframes fadeUp { from { opacity:0; transform: translateY(20px); } to { opacity:1; transform: translateY(0); } }
  .fade-up { animation: fadeUp 0.4s ease forwards; }
  @keyframes pulse { 0%,100%{ transform: scale(1); } 50%{ transform: scale(1.05); } }
  .pulse { animation: pulse 0.3s ease; }

  .confetti-burst { animation: pulse 0.4s ease; }
</style>
</head>
<body>

<div class="bg-glow"></div>
<div class="toast" id="toast"></div>

<!-- ============================================================ -->
<!-- PAGE 1: INSCRIPTION -->
<!-- ============================================================ -->
<div class="page active" id="page-inscription">
  <nav class="nav">
    <div class="nav-logo">Work<span>Flow</span> Africa</div>
  </nav>
  <div style="flex:1; position:relative; z-index:1;">
    <div class="hero">
      <div class="hero-badge">🌍 Plateforme #1 en Afrique de l'Ouest</div>
      <h1 class="hero-title">Gagnez de l'argent<br>en ligne <span>chaque jour</span></h1>
      <p class="hero-desc">Accomplissez des missions simples sur TikTok & Facebook et recevez votre rémunération immédiatement.</p>
    </div>

    <div class="content fade-up">
      <div class="steps">
        <div class="step"><div class="step-num active">1</div></div>
        <div class="step-line"></div>
        <div class="step"><div class="step-num">2</div></div>
        <div class="step-line"></div>
        <div class="step"><div class="step-num">3</div></div>
      </div>

      <div class="card">
        <h2 class="page-title" style="font-size:1.4rem; margin-bottom:4px;">Créer mon compte</h2>
        <p class="page-sub" style="margin-bottom:24px;">Inscription rapide et gratuite</p>

        <div class="form-group">
          <label class="form-label">Nom *</label>
          <input class="form-input" type="text" id="nom" placeholder="Ex: Konaté" />
        </div>
        <div class="form-group">
          <label class="form-label">Prénom *</label>
          <input class="form-input" type="text" id="prenom" placeholder="Ex: Aminata" />
        </div>
        <div class="form-group">
          <label class="form-label">Adresse Gmail *</label>
          <input class="form-input" type="email" id="email" placeholder="exemple@gmail.com" />
        </div>
        <div class="form-group">
          <label class="form-label">Numéro de téléphone *</label>
          <div style="display:flex; gap:10px; flex-wrap:wrap;">
            <select class="form-input" id="tel-indicatif" style="width:auto; min-width:190px; cursor:pointer;">
              <option value="+225">🇨🇮 +225 — Côte d'Ivoire</option>
              <option value="+221">🇸🇳 +221 — Sénégal</option>
              <option value="+223">🇲🇱 +223 — Mali</option>
              <option value="+226">🇧🇫 +226 — Burkina Faso</option>
              <option value="+227">🇳🇪 +227 — Niger</option>
              <option value="+228">🇹🇬 +228 — Togo</option>
              <option value="+229">🇧🇯 +229 — Bénin</option>
              <option value="+245">🇬🇼 +245 — Guinée-Bissau</option>
              <option value="+237">🇨🇲 +237 — Cameroun</option>
              <option value="+236">🇨🇫 +236 — Centrafrique</option>
              <option value="+235">🇹🇩 +235 — Tchad</option>
              <option value="+242">🇨🇬 +242 — Congo-Brazzaville</option>
              <option value="+241">🇬🇦 +241 — Gabon</option>
              <option value="+240">🇬🇶 +240 — Guinée équatoriale</option>
              <option value="+269">🇰🇲 +269 — Comores</option>
            </select>
            <input class="form-input" type="tel" id="tel" placeholder="07 00 00 00 00" style="flex:1; min-width:140px;" />
          </div>
        </div>

        <button class="btn-primary" onclick="validerInscription()">Valider</button>
      </div>
    </div>
  </div>
</div>

<!-- ============================================================ -->
<!-- PAGE 2: PAIEMENT -->
<!-- ============================================================ -->
<div class="page" id="page-paiement">
  <nav class="nav">
    <div class="nav-logo">Work<span>Flow</span> Africa</div>
    <div class="nav-links">
      <button class="nav-btn" onclick="goTo('page-inscription')">← Retour</button>
    </div>
  </nav>
  <div class="content fade-up" style="position:relative;z-index:1;">
    <div class="steps" style="margin-top:28px;">
      <div class="step"><div class="step-num done">✓</div></div>
      <div class="step-line done"></div>
      <div class="step"><div class="step-num active">2</div></div>
      <div class="step-line"></div>
      <div class="step"><div class="step-num">3</div></div>
    </div>

    <h2 class="page-title">Choisir mon <span>dépôt</span></h2>
    <p class="page-sub">Votre dépôt détermine vos missions et vos gains journaliers</p>

    <div class="card">
      <p class="section-title" style="font-size:0.85rem;">Montant du dépôt</p>
      <div class="payment-grid">
        <div class="payment-option" onclick="selectPayment(this, 5000)">
          <div class="check">💳</div>
          <div class="amount">5 000</div>
          <div class="currency">FCFA</div>
        </div>
        <div class="payment-option" onclick="selectPayment(this, 10000)">
          <div class="check">💳</div>
          <div class="amount">10 000</div>
          <div class="currency">FCFA</div>
        </div>
        <div class="payment-option" onclick="selectPayment(this, 20000)">
          <div class="check">💳</div>
          <div class="amount">20 000</div>
          <div class="currency">FCFA</div>
        </div>
        <div class="payment-option" onclick="selectPayment(this, 30000)">
          <div class="check">💳</div>
          <div class="amount">30 000</div>
          <div class="currency">FCFA</div>
        </div>
        <div class="payment-option" onclick="selectPayment(this, 40000)">
          <div class="check">💳</div>
          <div class="amount">40 000</div>
          <div class="currency">FCFA</div>
        </div>
        <div class="payment-option" onclick="selectPayment(this, 50000)">
          <div class="check">💳</div>
          <div class="amount">50 000</div>
          <div class="currency">FCFA</div>
        </div>
        <div class="payment-option" onclick="selectPayment(this, 60000)">
          <div class="check">💳</div>
          <div class="amount">60 000</div>
          <div class="currency">FCFA</div>
        </div>
        <div class="payment-option" onclick="selectPayment(this, 70000)">
          <div class="check">💳</div>
          <div class="amount">70 000</div>
          <div class="currency">FCFA</div>
        </div>
        <div class="payment-option" onclick="selectPayment(this, 80000)">
          <div class="check">💳</div>
          <div class="amount">80 000</div>
          <div class="currency">FCFA</div>
        </div>
        <div class="payment-option" onclick="selectPayment(this, 90000)">
          <div class="check">💎</div>
          <div class="amount">90 000</div>
          <div class="currency">FCFA</div>
        </div>
        <div class="payment-option" onclick="selectPayment(this, 100000)">
          <div class="check">⭐</div>
          <div class="amount">100 000</div>
          <div class="currency">FCFA</div>
        </div>
      </div>

      <div id="payment-detail" style="display:none; background:var(--dark3); border-radius:10px; padding:16px; margin-bottom:20px;">
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:8px;">
          <span style="color:var(--muted); font-size:0.85rem;">Dépôt sélectionné</span>
          <span id="payment-amount-display" style="font-family:var(--font-head); font-weight:700; color:var(--gold); font-size:1.1rem;"></span>
        </div>
        <div style="display:flex; justify-content:space-between; align-items:center;">
          <span style="color:var(--muted); font-size:0.85rem;">Gains estimés/jour</span>
          <span id="payment-gains" style="font-family:var(--font-head); font-weight:600; color:var(--green); font-size:0.95rem;"></span>
        </div>
      </div>

      <div style="background:rgba(245,197,24,0.08); border:1px solid rgba(245,197,24,0.2); border-radius:10px; padding:14px; margin-bottom:20px; font-size:0.85rem; color:var(--muted);">
        💡 <strong style="color:var(--text);">Mode démo</strong> — Aucun vrai paiement n'est effectué. Ceci est une simulation.
      </div>

      <button class="btn-primary" onclick="validerPaiement()" id="btn-payer" disabled style="opacity:0.5;">
        Valider le paiement
      </button>
    </div>
  </div>
</div>

<!-- ============================================================ -->
<!-- PAGE 3: TABLEAU DES TÂCHES -->
<!-- ============================================================ -->
<div class="page" id="page-taches">
  <nav class="nav">
    <div class="nav-logo">Work<span>Flow</span> Africa</div>
