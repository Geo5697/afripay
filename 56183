// ── TASKS ───────────────────────────────────────────────────
function loadTasksState() {
  const key = 'taskpay_tasks_' + getTodayKey();
  const state = JSON.parse(localStorage.getItem(key) || '{}');
  tasksCompleted = Object.values(state).filter(v => v === 'done').length;
  renderTasks(state);
  updateSidebar();
}

function renderTasks(state) {
  const container = document.getElementById('tasksList');
  if (!container) return;
  container.innerHTML = '';

  DEMO_TASKS.forEach(task => {
    const status = state[task.id] || 'idle';
    const isDone = status === 'done';

    const card = document.createElement('div');
    card.className = 'task-card' + (isDone ? ' done' : '');
    card.id = 'task-' + task.id;
    card.innerHTML = `
      <div class="task-media">
        <img src="${task.media}" alt="${task.platform}" loading="lazy" onerror="this.style.display='none';this.parentNode.textContent='${task.icon}'" />
      </div>
      <div class="task-info">
        <div class="task-platform">${task.icon} ${task.platform}</div>
        <h3>${task.title}</h3>
        <p>${task.desc}</p>
        <div class="task-reward">+${formatNum(task.reward)} FCFA</div>
      </div>
      <div class="task-actions">
        ${isDone
          ? `<button class="btn-task btn-completed" disabled>✓ Terminé</button>`
          : status === 'started'
          ? `<button class="btn-task btn-done" onclick="completeTask(${task.id})">Terminé ✓</button>`
          : `<button class="btn-task btn-start" onclick="startTask(${task.id}, '${task.link}')">Commencer</button>`
        }
      </div>
    `;
    container.appendChild(card);
  });

  // Progress
  const pct = (tasksCompleted / TASKS_PER_DAY) * 100;
  const bar = document.getElementById('progressBar');
  if (bar) bar.style.width = pct + '%';
}

function startTask(id, link) {
  const key = 'taskpay_tasks_' + getTodayKey();
  const state = JSON.parse(localStorage.getItem(key) || '{}');
  state[id] = 'started';
  localStorage.setItem(key, JSON.stringify(state));

  // Open task link
  if (link && link !== '#') window.open(link, '_blank');

  // Update button
  const card = document.getElementById('task-' + id);
  if (card) {
    const actions = card.querySelector('.task-actions');
    actions.innerHTML = `<button class="btn-task btn-done" onclick="completeTask(${id})">Terminé ✓</button>`;
  }
  toast('Tâche commencée ! Effectuez l\'action puis cliquez "Terminé".', 'info');
}

function completeTask(id) {
  const key = 'taskpay_tasks_' + getTodayKey();
  const state = JSON.parse(localStorage.getItem(key) || '{}');
  state[id] = 'done';
  localStorage.setItem(key, JSON.stringify(state));

  tasksCompleted++;

  // Update earnings
  if (currentUser) {
    currentUser.earnings = (currentUser.earnings || 0) + REWARD_PER_TASK;
    localStorage.setItem('taskpay_user', JSON.stringify(currentUser));
  }

  // Record task in admin
  recordTask(id);
  // Add to history
  addHistory('Tâche #' + id, REWARD_PER_TASK, 'succès');

  // Update UI
  const card = document.getElementById('task-' + id);
  if (card) {
    card.classList.add('done');
    card.querySelector('.task-actions').innerHTML = `<button class="btn-task btn-completed" disabled>✓ Terminé</button>`;
  }

  updateSidebar();
  const pct = (tasksCompleted / TASKS_PER_DAY) * 100;
  const bar = document.getElementById('progressBar');
  if (bar) bar.style.width = pct + '%';

  toast('🎉 +' + formatNum(REWARD_PER_TASK) + ' FCFA crédités !');

  if (tasksCompleted === TASKS_PER_DAY) {
    setTimeout(() => {
      showModal('modal-success',
        'Félicitations ! 🏆',
        `Vous avez complété toutes vos ${TASKS_PER_DAY} tâches d'aujourd'hui ! Total gagné : ${formatNum(currentUser.earnings)} FCFA.`
      );
    }, 500);
  }
}

function updateSidebar() {
  const remaining = TASKS_PER_DAY - tasksCompleted;
  const el = document.getElementById('tasksLeft');
  const earned = document.getElementById('totalEarned');
  const wbal = document.getElementById('withdrawBalance');

  if (el) el.textContent = remaining;
  if (earned) earned.textContent = formatNum(currentUser?.earnings || 0);
  if (wbal) wbal.textContent = formatNum(currentUser?.earnings || 0) + ' FCFA';
}

function initDashboard() {
  if (!currentUser) return;
  const avatar = document.getElementById('sidebarAvatar');
  const name   = document.getElementById('sidebarName');
  const email  = document.getElementById('sidebarEmail');

  if (avatar) avatar.textContent = (currentUser.prenom || 'U')[0].toUpperCase();
  if (name)   name.textContent   = (currentUser.prenom || '') + ' ' + (currentUser.nom || '');
  if (email)  email.textContent  = currentUser.email || '';

  updateSidebar();
  loadTasksState();
}

// ── WITHDRAW ────────────────────────────────────────────────
function requestWithdraw(e) {
  e.preventDefault();
  const network = document.getElementById('network').value;
  const phone   = document.getElementById('withdrawPhone').value.trim();
  const amount  = parseInt(document.getElementById('withdrawAmount').value);
  const idFile  = document.getElementById('idCard').files[0];

  if (!network) return toast('Sélectionnez un réseau mobile.', 'error');
  if (!phone)   return toast('Entrez votre numéro de téléphone.', 'error');
  if (!amount || amount < 50000) return toast('Le montant minimum est de 50 000 FCFA.', 'warning');
  if ((currentUser?.earnings || 0) < 50000) return toast('Solde insuffisant pour un retrait.', 'warning');
  if (!idFile)  return toast('Veuillez uploader votre pièce d\'identité.', 'error');

  // Record withdrawal request
  const withdrawals = JSON.parse(localStorage.getItem('taskpay_withdrawals') || '[]');
  withdrawals.push({
    id: Date.now(),
    user_id: currentUser?.id,
    user_name: (currentUser?.prenom || '') + ' ' + (currentUser?.nom || ''),
    amount, network, phone,
    date: new Date().toLocaleDateString('fr-FR'),
    status: 'en attente'
  });
  localStorage.setItem('taskpay_withdrawals', JSON.stringify(withdrawals));

  addHistory('Retrait', amount, 'en attente');

  document.getElementById('modal-withdraw').classList.add('open');
}

function previewId(input) {
  const file = input.files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = (e) => {
    const img = document.getElementById('idPreview');
    img.src = e.target.result;
    img.style.display = 'block';
    document.getElementById('uploadIcon').style.display = 'none';
    document.getElementById('uploadText').style.display = 'none';
  };
  reader.readAsDataURL(file);
}

// ── HISTORY ─────────────────────────────────────────────────
function addHistory(type, amount, status) {
  const history = JSON.parse(localStorage.getItem('taskpay_history_' + (currentUser?.id || 'guest')) || '[]');
  history.unshift({
    date: new Date().toLocaleDateString('fr-FR'),
    type, amount, status
  });
  localStorage.setItem('taskpay_history_' + (currentUser?.id || 'guest'), JSON.stringify(history));
  loadHistory();
}

function loadHistory() {
  const tbody = document.getElementById('historyTable');
  if (!tbody) return;
  const history = JSON.parse(localStorage.getItem('taskpay_history_' + (currentUser?.id || 'guest')) || '[]');
  if (!history.length) {
    tbody.innerHTML = '<tr><td colspan="4" style="text-align:center;color:var(--muted);padding:32px;">Aucune transaction</td></tr>';
    return;
  }
  tbody.innerHTML = history.map(h => `
    <tr>
      <td>${h.date}</td>
      <td>${h.type}</td>
      <td>${formatNum(h.amount)} FCFA</td>
      <td><span class="badge ${h.status === 'succès' ? 'badge-success' : h.status === 'en attente' ? 'badge-warning' : 'badge-info'}">${h.status}</span></td>
    </tr>
  `).join('');
}

