  user.date = new Date().toLocaleDateString('fr-FR');
  users.push(user);
  localStorage.setItem('taskpay_users', JSON.stringify(users));
}

function recordTask(taskId) {
  const allTasks = JSON.parse(localStorage.getItem('taskpay_all_tasks') || '[]');
  const task = DEMO_TASKS.find(t => t.id === taskId);
  allTasks.push({
    user_id:    currentUser?.id,
    user_name:  (currentUser?.prenom || '') + ' ' + (currentUser?.nom || ''),
    task_title: task?.title || 'Tâche #' + taskId,
    platform:   task?.platform || '—',
    date:       new Date().toLocaleDateString('fr-FR')
  });
  localStorage.setItem('taskpay_all_tasks', JSON.stringify(allTasks));
}

function getTodayKey() {
  return new Date().toISOString().split('T')[0] + '_' + (currentUser?.id || 'guest');
}

function formatNum(n) {
  return (n || 0).toLocaleString('fr-FR');
}

function showModal(id, title, text) {
  document.getElementById('modal-success-title').textContent = title;
  document.getElementById('modal-success-text').textContent = text;
  document.getElementById('modal-success').classList.add('open');
}

function logout() {
  currentUser = null;
  localStorage.removeItem('taskpay_user');
  showPage('page-login');
  toast('Vous êtes déconnecté.', 'warning');
}

