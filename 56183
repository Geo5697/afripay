  const btn = document.getElementById('registerBtn');
  btn.innerHTML = '<span class="spinner"></span> Création…';
  btn.disabled = true;

  // Simulated API call (replace with fetch to register.php)
  await apiCall('register.php', { nom, prenom, email, password: pass, indicatif, telephone: tel }, (data) => {
    currentUser = { nom, prenom, email, telephone: indicatif + tel, id: data.id || Date.now(), earnings: 0 };
    localStorage.setItem('taskpay_user', JSON.stringify(currentUser));
